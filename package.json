{
  "name": "math-marsh",
  "description": "Educational math game for practicing arithmetic equations.",
  "author": {
    "name": "DeeGee Games",
    "email": "contact@deegeegames.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/deegeegames/math-marsh.git"
  },
  "bugs": {
    "url": "https://github.com/deegeegames/math-marsh/issues"
  },
  "homepage": "https://deegeegames.github.io/math-marsh/",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "desktopName": "math-marsh",
  "scripts": {
    "dev": "bun --port 3000 --console index.html",
    "build": "bun run typecheck && bun run scripts/build.ts",
    "desktop:dev": "bun run scripts/desktop-dev.ts",
    "desktop:build": "bun run scripts/desktop-build.ts",
    "desktop:check": "bun run typecheck && bun run scripts/desktop-build.ts",
    "desktop:package:linux": "bun run desktop:build && electron-builder --linux --publish never",
    "desktop:package:win": "bun run desktop:build && electron-builder --win --publish never",
    "check": "bun run lint && bun run test && bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "preview": "bun run scripts/preview.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/howler": "^2.2.13",
    "bun-plugin-tailwind": "^0.1.2",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.3.3",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "ecspresso": "^0.20.0",
    "howler": "^2.2.4",
    "lit-html": "^3.3.3",
    "typescript-eslint": "^8.64.0"
  },
  "build": {
    "appId": "com.deegeegames.mathmarsh",
    "productName": "Math Marsh",
    "executableName": "math-marsh",
    "artifactName": "math-marsh-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "desktop-dist"
    },
    "files": [
      "dist/**",
      "electron/**",
      "!electron/launch.sh",
      "src/assets/images/math-marsh-icon.png",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "electron/launch.sh",
        "to": "launch.sh"
      }
    ],
    "electronLanguages": [
      "en-US"
    ],
    "linux": {
      "target": [
        "AppImage",
        "dir"
      ],
      "icon": "src/assets/images/math-marsh-icon.png",
      "category": "Game",
      "executableArgs": [
        "--no-sandbox"
      ],
      "syncDesktopName": true
    },
    "win": {
      "target": [
        "nsis",
        "zip",
        "dir"
      ],
      "icon": "src/assets/images/math-marsh-icon.png"
    }
  }
}